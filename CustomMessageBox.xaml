<Window x:Class="LotusPecasApkInstaller.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        SizeToContent="Height" Width="440" ShowInTaskbar="False"
        FontFamily="Segoe UI">
    <Border CornerRadius="16" Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="2"
            MouseLeftButtonDown="Border_Drag">
        <Border.Effect>
            <DropShadowEffect Color="#1ABC9C" BlurRadius="28" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0" Padding="20,14">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{StaticResource PrimaryColor}" Offset="0"/>
                        <GradientStop Color="{StaticResource AccentColor}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TitleText" Grid.Column="0" FontSize="17" FontWeight="Bold" Foreground="White"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="✕" Width="28" Height="28" FontSize="14" FontWeight="Bold"
                            Foreground="White" Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Click="Close_Click"/>
                </Grid>
            </Border>

            <!-- Body -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="24,20">
                <TextBlock x:Name="IconText" FontSize="40" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock x:Name="MessageText" FontSize="14" Foreground="{StaticResource TextBrush}"
                           TextWrapping="Wrap" VerticalAlignment="Center" MaxWidth="340"/>
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Padding="20,12" Background="#D1F2EB" CornerRadius="0,0,14,14">
                <Button x:Name="OkButton" Content="OK" Style="{StaticResource TurquoiseButton}"
                        MinWidth="100" HorizontalAlignment="Right" Click="Ok_Click" IsDefault="True"/>
            </Border>
        </Grid>
    </Border>
</Window>
