<Window x:Class="LotusPecasApkInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lotus Pecas APK Installer v1.0.0" Height="820" Width="720" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" CornerRadius="12" Padding="20" Margin="0,0,0,16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource PrimaryColor}" Offset="0"/>
                    <GradientStop Color="{StaticResource AccentColor}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#1ABC9C" BlurRadius="20" ShadowDepth="3" Opacity="0.4"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="🌸 Lotus Pecas APK Installer" FontSize="26" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="SubtitleText" Text="Android cihazlara APK yükle" FontSize="13" Foreground="#E0F7F5" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Margin="4,0" Padding="0" Cursor="Hand" Background="Transparent"
                            BorderThickness="0" Tag="tr" Click="Language_Click" ToolTip="Türkçe">
                        <Border CornerRadius="3" Width="42" Height="28" BorderBrush="#E0F7F5" BorderThickness="1"
                                ClipToBounds="True" SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.3"/>
                            </Border.Effect>
                            <Grid Background="#E30A17">
                                <!-- crescent: white circle with red overlay -->
                                <Ellipse Width="14" Height="14" Fill="White"
                                         HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                <Ellipse Width="11" Height="11" Fill="#E30A17"
                                         HorizontalAlignment="Left" VerticalAlignment="Center" Margin="13,0,0,0"/>
                                <!-- 5-point star -->
                                <Path Fill="White" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="25,0,0,0"
                                      Data="M 5,0 L 6.2,3.6 L 10,3.6 L 6.9,5.8 L 8.1,9.4 L 5,7.2 L 1.9,9.4 L 3.1,5.8 L 0,3.6 L 3.8,3.6 Z"/>
                            </Grid>
                        </Border>
                    </Button>
                    <Button Margin="4,0" Padding="0" Cursor="Hand" Background="Transparent"
                            BorderThickness="0" Tag="de" Click="Language_Click" ToolTip="Deutsch">
                        <Border CornerRadius="3" Width="42" Height="28" BorderBrush="#E0F7F5" BorderThickness="1"
                                ClipToBounds="True" SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.3"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Rectangle Grid.Row="0" Fill="#000000"/>
                                <Rectangle Grid.Row="1" Fill="#DD0000"/>
                                <Rectangle Grid.Row="2" Fill="#FFCE00"/>
                            </Grid>
                        </Border>
                    </Button>
                    <Button Margin="4,0" Padding="0" Cursor="Hand" Background="Transparent"
                            BorderThickness="0" Tag="fr" Click="Language_Click" ToolTip="Français">
                        <Border CornerRadius="3" Width="42" Height="28" BorderBrush="#E0F7F5" BorderThickness="1"
                                ClipToBounds="True" SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.3"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Fill="#0055A4"/>
                                <Rectangle Grid.Column="1" Fill="#FFFFFF"/>
                                <Rectangle Grid.Column="2" Fill="#EF4135"/>
                            </Grid>
                        </Border>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Device selection -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="DeviceLabel" Grid.Column="0" Text="Cihaz:" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <ComboBox x:Name="DeviceComboBox" Grid.Column="1" VerticalAlignment="Center"/>
                <Button x:Name="RefreshButton" Grid.Column="2" Content="🔄 Yenile" Style="{StaticResource OutlineButton}"
                        Margin="12,0,0,0" Click="RefreshDevices_Click"/>
            </Grid>
        </Border>

        <!-- IP Connect -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="IpLabel" Grid.Column="0" Text="IP:" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBox x:Name="IpTextBox" Grid.Column="1" VerticalAlignment="Center"
                         Padding="8" FontSize="13" BorderBrush="{StaticResource PrimaryBrush}"
                         ToolTip="Örn: 192.168.1.42 veya 192.168.1.42:5555"/>
                <Button x:Name="ConnectButton" Grid.Column="2" Content="🔌 Bağlan" Style="{StaticResource OutlineButton}"
                        Margin="12,0,0,0" Click="ConnectIp_Click"/>
                <Button x:Name="DisconnectButton" Grid.Column="3" Content="⏏ Kes" Style="{StaticResource OutlineButton}"
                        Margin="6,0,0,0" Click="DisconnectIp_Click"/>
            </Grid>
        </Border>

        <!-- APK selection -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ApkLabel" Grid.Column="0" Text="APK:" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBox x:Name="ApkPathTextBox" Grid.Column="1" IsReadOnly="True" VerticalAlignment="Center"
                         Padding="8" FontSize="13" BorderBrush="{StaticResource PrimaryBrush}"
                         Text="APK dosyası seçilmedi..."/>
                <Button x:Name="BrowseButton" Grid.Column="2" Content="📂 Gözat" Style="{StaticResource OutlineButton}"
                        Margin="12,0,0,0" Click="BrowseApk_Click"/>
            </Grid>
        </Border>

        <!-- Install button -->
        <Button Grid.Row="4" x:Name="InstallButton" Content="⬇  APK Yükle" Style="{StaticResource TurquoiseButton}"
                FontSize="16" Padding="24,14" HorizontalAlignment="Stretch" Margin="0,4,0,12"
                Click="Install_Click"/>

        <!-- Log -->
        <Border Grid.Row="5" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="12" MinHeight="260">
            <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogText" FontFamily="Consolas" FontSize="12"
                           Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="6" Background="{StaticResource PrimaryDarkBrush}" CornerRadius="6" Padding="10,6" Margin="0,12,0,0">
            <TextBlock x:Name="StatusText" Text="Hazır" Foreground="White" FontSize="12"/>
        </Border>
    </Grid>
</Window>
